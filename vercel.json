{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "regions": ["gru1"],
  "cleanUrls": true,
  "functions": {
    "api/gerar.js":    { "maxDuration": 60 },
    "api/webhook.js":  { "maxDuration": 10 },
    "api/checkout.js": { "maxDuration": 10 },
    "api/portal.js":   { "maxDuration": 10 },
    "api/me.js":       { "maxDuration": 10 },
    "api/config.js":   { "maxDuration": 5  }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net 'unsafe-inline'; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://*.supabase.co https://api.stripe.com; img-src 'self' data:; object-src 'none'; base-uri 'self';"
        }
      ]
    }
  ]
}

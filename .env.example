# Chave da API Anthropic (obrigatória)
ANTHROPIC_API_KEY=sk-ant-...

# Segredo para assinar tokens HMAC (obrigatório) — string aleatória >= 32 chars
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=gere-um-segredo-aleatorio-aqui

# Origem permitida no CORS em produção (obrigatório em prod)
# Exemplo: https://peti.pro
ALLOWED_ORIGIN=https://seu-dominio.vercel.app

# Ambiente (definido automaticamente pela Vercel; só defina localmente se necessário)
NODE_ENV=development

# Rate limit persistente via Upstash Redis — pré-requisito antes de abrir trial público.
# Sem essas variáveis, o rate limit in-memory é usado (não escala em serverless multi-instância).
# Configure em: https://vercel.com/integrations/upstash
# UPSTASH_REDIS_REST_URL=https://...upstash.io
# UPSTASH_REDIS_REST_TOKEN=...
